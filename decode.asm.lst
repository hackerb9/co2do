                        	;; Given a destination address and the varptr of a BASIC
                        	;; string, copy the source string to the destination,
                        	;; processing !-escapes by replacing each '!' with the
                        	;; subsequent character with the high-bit flipped.

                        	;; Calling is a two step process. First, the destination
                        	;; address is sent from BASIC in HL by calling DCINIT.
                        	;; Second, MAIN (= DCINIT+6) is called with the varptr of
                        	;; the source string in HL.

                        	;; Upon return, the length of the source string is modified to
                        	;; reflect the actual number of characters written to the
                        	;; destination address. The source string data is NOT changed.

                        	;; Example usage from BASIC:
                        	;;      10 DC=(DCINIT address after relocation)
                        	;;      20 Q=(destination buffer address)
                        	;; 	30 READ P$: IF P$="EOD" THEN END
                        	;;  	40 CALL DC, 0, Q
                        	;; 	50 CALL DC+6, 0, VARPTR(P$)
                        	;; 	60 Q=Q+LEN(P$)
                        	;; 	70 GOTO 30
                        	;;
                        	;; When appending multiple strings to the same buffer, the
                        	;; destination address does not need to be updated each time.
                        	;; The following is equivalent to the above code:

                        	;;      10 DC=(DCINIT address after relocation)
                        	;;  	20 CALL DC, 0, (destination buffer address)
                        	;; 	30 READ P$: IF P$="EOD" THEN END
                        	;; 	40 CALL DC+6, 0, VARPTR(P$)
                        	;; 	50 GOTO 30

0000                    	CPU 8085

0000                    	ORG 0			; The BASIC loader relocates this routine.
0000                    DCINIT:	
0000  22 0400           	SHLD DEST		; Save HL in DEST as destination address.
0003  C9                	RET

0004  0000              DEST:	DW 0

0006                    MAIN:	
                        	;; HL starts as VARPTR(P$) where P$ is bang-encoded.
0006  E5                	PUSH H
0007  46                	MOV B, M		; B is length of input string
0008  0E 00             	MVI C, 0		; C will be resulting length
000A  23                	INX H
000B  5E                	MOV E, M		; Load actual address of string into DE
000C  23                	INX H
000D  56                	MOV D, M
000E  2A 0400           	LHLD DEST		; Restore HL from saved DEST
0011  EB                	XCHG			; Now HL is P$'s actual address
                        				; and DE is address of destination
0012  78                	MOV A, B
0013  A7                	ANA A
0014  CA 3100           	JZ END			; Zero-length string?
0017                    LOOP:	
0017  7E                	MOV A, M		; Get next byte from source (*HL)
0018  FE 21             	CPI '!'
001A  C2 2500           	JNZ WRITE		; If not '!' just copy the character.
001D  05                	DCR B
001E  CA 3100           	JZ END			; Ignore escape char with no following char.
0021  23                	INX H			; Char is '!' so get next char in A
0022  7E                	MOV A, M
0023  EE 80             	XRI 128			; Decode character by flipping bit 7
0025                    WRITE:	
0025  EB                	XCHG
0026  D6 88             	SUI 136			; XXX Testing offset: Subtract 136 from char
0028  77                	MOV M, A		; Copy the byte from *HL to *DE.
0029  EB                	XCHG
002A  23                	INX H
002B  13                	INX D
002C  0C                	INR C
002D  05                	DCR B
002E  C2 1700           	JNZ LOOP
0031                    END:	
0031  EB                	XCHG			; Save DE in DEST so next call can skip DCINIT
0032  22 0400           	SHLD DEST
0035  EB                	XCHG			; Not needed, just being overly fastidious
0036  E1                	POP H
0037  71                	MOV M, C		; Write new length to BASIC string
                        	
0038  C9                	RET

00000 Total Error(s)

DCINIT             00000000    DEST               00000004    END                00000031
LOOP               00000017    MAIN               00000006    WRITE              00000025
