                        	;; Given an address to copy to and the varptr of a BASIC
                        	;; string, remove the ! escapes by replacing with the next
                        	;; character minus 128.
                        	;;
                        	;; Destination address is sent from BASIC in HL by calling SETUP.
                        	;; The varptr of the string is in HL by calling MAIN.
                        	;; MAIN gets the destination addresss from where SETUP stashed it.

0000                    	CPU 8085

0000                    	ORG 0
0000                    SETUP:	
0000  22 0400           	SHLD DEST		; Save HL in DESt as destination address.
0003  C9                	RET

0004  0000              DEST:	DW 0

0006                    MAIN:	
                        	;; HL is VARPTR(P$) where P$ is bang-encoded.
0006  E5                	PUSH H
0007  46                	MOV B, M		; B is length of input string
0008  0E 00             	MVI C, 0		; C will be resulting length
000A  23                	INX H
000B  5E                	MOV E, M		; Load actual address of string into DE
000C  23                	INX H
000D  56                	MOV D, M
                        	
000E  2A 0400           	LHLD DEST		; Restore HL from saved DEST
0011  EB                	XCHG			; Now HL is P$'s actual address
                        				; and DE is address of destination
0012  78                	MOV A, B
0013  A7                	ANA A
0014  CA 2F00           	JZ END			; Zero-length string?
0017                    LOOP:	
0017  7E                	MOV A, M		; Get next byte from source (*HL)
0018  FE 21             	CPI '!'
001A  C2 2500           	JNZ WRITE		; If not '!' just copy the character.
001D  05                	DCR B
001E  CA 2F00           	JZ END			; Ignore escape char with no following char.
0021  23                	INX H			; Char is '!' so get next char in A
0022  7E                	MOV A, M
0023  EE 80             	XRI 128			; Decode character by flipping bit 7
0025                    WRITE:	
0025  EB                	XCHG
0026  77                	MOV M, A		; Copy the byte from *HL to *DE.
0027  EB                	XCHG
0028  23                	INX H
0029  13                	INX D
002A  0C                	INR C
002B  05                	DCR B
002C  C2 1700           	JNZ LOOP
002F                    END:	
002F  E1                	POP H
0030  71                	MOV M, C		; Write new length to BASIC string
                        	
0031  C9                	RET

00000 Total Error(s)

DEST               00000004    END                0000002F    LOOP               00000017
MAIN               00000006    SETUP              00000000    WRITE              00000025
