10 'MAZE1.BAS
11 '
12 '3-D Maze program, finally reborn
13 '
14 'By Kurt W. Dekker
15 '
16 'on 10/04/90
17 '
20 H=119-32	' half the screen width
30 S=.4		' distance to screen
40 MX=5:MY=5:SF=.2
45 LY=40:LX=239-64
50 DIMZ%(MX,MY)	' maze array
70 TV=(239-64)
80 KX=64/(MX+1)
90 KY=64/(MY+1)
100 FOR A=0 TO 5
200 X=A+.5
300 V=(S/X)*H
400 PRINT USING"#:###.#";A,V
450 V(A+1)=H-V
500 NEXT
600 V(0)=0
700 P2(0)=1:P2(1)=8:P2(2)=4:P2(3)=2	' map directions to bits
1000 CLS
1100 PRINT"MAZE V1.0 by Kurt W. Dekker"
1150 PRINT
1200 PRINT"Press <Enter> to start generating maze"
1300 A=RND(1):IF INKEY$="" THEN 1300
1400 PRINT"Generating..."
2000 FOR A=0 TO MX
2100 FOR B=0 TO MY
2200 Z%(A,B)=Z%(A,B) OR INT(RND(1)*2)
2300 Z%(A,B)=Z%(A,B) OR INT(RND(1)*2)*2
2400 NEXT:NEXT
2500 FOR A=0 TO MX
2600 FOR B=0 TO MY
2700 IF A>0 THEN Z%(A-1,B)=Z%(A-1,B) OR ((Z%(A,B) AND 2)*4)
2800 IF B>0 THEN Z%(A,B-1)=Z%(A,B-1) OR ((Z%(A,B) AND 1)*4)
2900 NEXT:NEXT
3000 FOR A=0 TO MX
3100 Z%(A,0)=Z%(A,0) OR 1
3200 Z%(A,MY)=Z%(A,MY) OR 4
3300 NEXT
3500 FOR A=0 TO MY
3600 Z%(0,A)=Z%(0,A) OR 2
3700 Z%(MX,A)=Z%(MX,A) OR 8
3800 NEXT
5000 GOSUB 50000
5100 N(0)=-1:M(1)=1:N(2)=1:M(3)=-1
6000 X=INT(MX/2):Y=INT(MY/2):D=0
10100 DL=D-1:IF DL<0 THEN DL=DL+4
10200 DR=D+1:IF DR>3 THEN DR=DR-4
10400 FOR R=0 TO 4
10450 X1=X+M(D)*R:Y1=Y+N(D)*R
10500 LINE(V(R+1),V(R+1)*SF)-(V(R+1),LY):LINE(LX-V(R+1),V(R+1)*SF)-(LX-V(R+1),LY)
10600 LINE(V(R+1),V(R+1)*SF)-(V(R+1),LY):LINE(LX-V(R+1),V(R+1)*SF)-(LX-V(R+1),LY)
11000 IF NOT(Z%(X1,Y1) AND P2(DL)) THEN 12000
11100 LINE(V(R),V(R)*SF)-(V(R+1),V(R+1)*SF)
12000 IF NOT(Z%(X1,Y1) AND P2(DR)) THEN 13000
12100 LINE(LX-V(R),V(R)*SF)-(LX-V(R+1),V(R+1)*SF)
13000 IF NOT(Z%(X1,Y1) AND P2(D)) THEN 20000
14000 LINE(V(R+1),V(R+1)*SF)-(LX-V(R+1),V(R+1)*SF)
15000 GOTO 21000	' hit a wall
20000 NEXT R
21000 PX=TV+KX*X+(KX/2)
21100 PY=KY*Y+(KY/2)
21200 PSET(PX,PY)
22000 GOTO 22000
49900 END
50000 CLS
50010 ' This routine prints a "TOP VIEW" of the maze
50300 FOR A=0 TO MX
50400 FOR B=0 TO MY
50500 IF Z%(A,B) AND 2 THEN LINE(TV+A*KX,B*KY)-(TV+A*KX,B*KY+KY-1)
50600 IF Z%(A,B) AND 1 THEN LINE(TV+A*KX,B*KY)-(TV+A*KX+KX-1,B*KY)
50700 IF Z%(A,B) AND 8 THEN LINE(TV+A*KX+KX-1,B*KY)-(TV+A*KX+KX-1,B*KY+KY-1)
50800 IF Z%(A,B) AND 4 THEN LINE(TV+A*KX,B*KY+KY-1)-(TV+A*KX+KX-1,B*KY+KY-1)
51000 NEXT:NEXT:RETURN
