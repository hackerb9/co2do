10 'tri-card game
20 '
30 'By Kurt W. Dekker
40 '
50 'tricard.bas
60 '
70 '4/25/90-4/26/90
80 '
90 '
95 R=VAL(TIME$)*3600+VAL(MID$(TIME$,4))*60+VAL(RIGHT$(TIME$,2)):R=RND(-R)
100 DIM SU$(3)
105 SI=0		'turns simulator on (only for statistics)
110 READ SU$(0),SU$(1),SU$(2),SU$(3)
120 DATA "","","",""
130 DIM VA$(12)
140 FOR A=0 TO 12:READ VA$(A):NEXT
150 DATA 2,3,4,5,6,7,8,9,T,J,Q,K,A
200 MO=100
210 HA=1
250 PRINT STRING$(40,"=");
260 IF MO=0 THEN 2000
300 PRINT "Hand #"HA;
400 FOR A=0 TO 2
410 CA(A)=INT(RND(1)*52)
420 IF A=0 THEN 460
430 FOR B=0 TO A-1
440 IF CA(A)=CA(B) THEN 410
450 NEXT B
460 NEXT A
470 F=0:FOR B=0 TO 1
480 IF CA(B)>CA(B+1) THEN T=CA(B):CA(B)=CA(B+1):CA(B+1)=T:F=1
490 NEXT:IF F THEN 470
600 FOR A=0 TO 2
610 SU(A)=INT(CA(A)/13)
620 VA(A)=CA(A) MOD 13
630 PRINT" "CHR$(27)"p["SU$(SU(A))VA$(VA(A))"]"CHR$(27)"q";
640 NEXT:PRINT
700 IF SI=0 THEN PRINT"Cash:"MO" - How much to bet:";
710 IF SI=0 THEN V$="":LINEINPUT V$:V=INT(VAL(V$)):IF V=0 THEN V=1:PRINT"Token bet of $1"
720 IF SI=0 AND V>MO THEN PRINT"You don't have that much cash!":GOTO 700
730 IF SI=0 THEN MO=MO-V
740 NC=INT(RND(1)*52) ' the NEXT card
750 FOR A=0 TO 2:IF NC=CA(A) THEN 740
760 NEXT
770 SU=INT(NC/13)
780 VA=NC MOD 13
800 PRINT"Card drawn: "CHR$(27)"p["SU$(SU)VA$(VA)"]"CHR$(27)"q"
900 HS=0:FOR A=0 TO 2
910 IF SU(A)<>SU THEN 950
920 HS=1	' you have the suit
930 IF VA(A)>VA THEN 1100
950 NEXT
955 IF SI THEN 1500
960 IF HS THEN PRINT"Your hand didn't beat that suit..." ELSE PRINT"Your hand didn't show that suit..."
1000 GOTO 250
1100 IF SI THEN 1400
1200 PRINT"***** WIN! *****   Payback:"V*2
1210 MO=MO+V*2
1220 GOTO 250
1400 WI=WI+1
1410 PRINT"Win...";
1450 GOTO 1550
1500 PRINT"Lose...";
1550 NG=NG+1
1600 PRINT USING"Percentage: ###.##";100*WI/NG
1700 GOTO 250
2000 PRINT"Game over!":END
