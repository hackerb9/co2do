4 '
10 CLEAR100,MAXRAM-300
20 DEFINTX,Y,Z,M,N,P,O
25 BB=HIMEM:AA=BB
30 AR$=CHR$(152)+CHR$(154)+CHR$(153)+CHR$(155)
35 DIMPW(3):PW(0)=1:PW(1)=2:PW(2)=4:PW(3)=8
40 INPUT"Maze # (0=replay)";A:IFA=0THEN700
50 A=RND(-A)
60 INPUT"Density (%):";CH
70 CH=CH/100
80 FORA=199TO0STEP-1:POKEBB+100+A,PEEK(BB+A):NEXT:PRINT".";
110 FORX=0TO9
120 FORY=0TO9
130 Z=0
140 GOSUB10000
150 NEXT:NEXT:PRINT".";
200 FORA=0TO9
210 Z=0:X=A:Y=0:GOSUB10300
220 Z=1:Y=A:X=9:GOSUB10300
230 Z=2:X=A:Y=9:GOSUB10300
240 Z=3:Y=A:X=0:GOSUB10300
250 NEXT
500 FORC=1TO2:PRINT".";
510 FORB=0TO9
520 FORA=0TO9
530 IFRND(1)>CHTHEN590
540 Z=C:X=A:Y=B
550 GOSUB10300
590 NEXT:NEXT:NEXT:PRINT".";
600 FORA=0TO9:FORB=0TO9
610 IFB=9THEN650
620 Z=2:X=A:Y=B:GOSUB10200
630 IFZ=0THEN650
640 Z=0:X=A:Y=B+1:GOSUB10300
650 IFA=9THEN690
660 Z=1:X=A:Y=B:GOSUB10200
670 IFZ=0THEN690
680 Z=3:X=A+1:Y=B:GOSUB10300
690 NEXT:PRINT".";:NEXT
700 M(0)=0:M(1)=1:M(2)=0:M(3)=-1
705 X1=5:Y1=5:SH=1
710 N(0)=-1:N(1)=0:N(2)=1:N(3)=0
730 RESTORE60000
740 C=120/18.333:FORA=0TO6:READB:O(A)=B*C:P(A)=B*C/2.4:NEXT
750 HI=47:WI=198
760 MN=1
770 XM=WI+20:YM=0
1000 D=0
1020 CLS
1030 GOSUB1930
1500 D1=D-1:IFD1<0THEND1=D1+4
1510 D2=D+1:IFD2>3THEND2=D2-4
1520 FORA=0TO5:PRINT@A*40,SPACE$(34);:NEXT
1530 LINE(0,0)-(WI,HI),1,B
1535 PRINT@40*6,"(x,y,d,m#)=("X1","Y1","D","MN")."
1537 PRINT@75,MID$(AR$,D+1,1)
1540 L1=0:L2=WI:FORI=0TO5:J=I-1:K=I+1
1545 IFSH=1THENA$=INKEY$:IFLEN(A$)THEN2010
1550 LINE(O(K),P(K))-(O(K),HI),1
1560 LINE(WI-O(K),P(K))-(WI-O(K),HI),1
1600 X=X1+M(D)*I:Y=Y1+N(D)*I
1650 Z=D1:GOSUB 10200
1660 IFZTHEN1730
1670 X=X1+M(D)*I+M(D1):Y=Y1+N(D)*I+N(D1)
1680 Z=D:GOSUB10200:IFZ=0THENGOSUB3000:GOTO1750
1690 LINE(L1,P(K))-(O(K),P(K)),1:L1=O(K)
1700 GOTO1750
1730 LINE(O(I),P(I))-(O(K),P(K)),1:L1=O(K)
1750 X=X1+M(D)*I:Y=Y1+N(D)*I
1765 Z=D2:GOSUB10200
1770 IFZTHEN1830
1775 X=X1+M(D)*I+M(D2):Y=Y1+N(D)*I+N(D2)
1780 Z=D:GOSUB10200:IFZ=0THENGOSUB3500:GOTO1860
1790 LINE(L2,P(K))-(WI-O(K),P(K)),1:L2=WI-O(K)
1800 GOTO 1860
1830 LINE(WI-O(I),P(I))-(WI-O(K),P(K)),1:L2=WI-O(K)
1860 X=X1+M(D)*I:Y=Y1+N(D)*I
1870 Z=D:GOSUB10200
1880 IFZTHEN1900
1890 NEXTI
1895 GOTO1910
1900 LINE(O(K),P(K))-(WI-O(K),P(K)),1
1910 REM
1925 GOTO2000
1930 LINE(XM+1,YM)-(239,238-XM),1,B:FORA=0TO10:FORB=0TO10:PSET(A*2+XM+1,YM+B*2)
1935 IFA=10ORB=10THEN1970
1940 Z=1:X=A:Y=B:GOSUB10200
1945 IFZTHENPSET(3+XM+A*2,YM+1+B*2)
1950 Z=2:X=A:Y=B:GOSUB10200
1960 IFZTHENPSET(2+XM+A*2,YM+B*2+2)
1970 NEXT:A$=INKEY$:IFLEN(A$)THEN2010
1972 NEXT
1975 LINE(208,6)-(216,16),1,B
1990 RETURN
2000 GOSUB9000
2010 IFA$="2"THENGOSUB2500
2020 IFA$="1"THEND=D-1:IFD<0THEND=D+4
2030 IFA$="3"THEND=D+1:IFD>3THEND=D-4
2040 IF(A$="u"ORA$="U")ANDMN<3THEN4000
2050 IF(A$="d"ORA$="D")ANDMN>1THEN4100
2060 IF A$=CHR$(13)THENSH=1-SH
2070 IFA$="#"THENGOSUB1930
2080 IFA$="$"THENCLS
2450 GOTO1500
2500 X=X1:Y=Y1:Z=D:GOSUB10200
2510 IFZ=0THENX1=X1+M(D):Y1=Y1+N(D):RETURN
2520 IFZTHENPRINT@134,"Bump!"
2530 A$=INPUT$(1)
2540 RETURN
3000 IFI>4THENRETURN
3010 X=X1+M(D)*K+M(D1):Y=Y1+N(D)*K+N(D1)
3020 Z=D:GOSUB10200
3030 IFZTHENLINE(L1,P(K+1))-(O(K),P(K+1)),1:RETURN
3040 X=X+M(D):Y=Y+N(D)
3050 Z=D:GOSUB10200
3060 IFZTHENLINE(L1,P(K+2))-(O(K),P(K+2)),1
3140 RETURN
3500 IFI>4THENRETURN
3510 X=X1+M(D)*K+M(D2):Y=Y1+N(D)*K+N(D2)
3520 Z=D:GOSUB10200
3530 IFZTHENLINE(L2,P(K+1))-(WI-O(K),P(K+1)),1:RETURN
3540 X=X+M(D):Y=Y+N(D)
3550 Z=D:GOSUB10200
3560 IFZTHENLINE(L2,P(K+2))-(WI-O(K),P(K+2)),1
3640 RETURN
4000 MN=MN+1
4050 AA=BB+(MN-1)*100
4060 GOTO1000
4100 MN=MN-1
4110 GOTO4050
9000 A$=INKEY$
9002 II=1-II:IFIITHENPSET(XM+2+X1*2,YM+Y1*2+1)
9004 IFII=0THENPRESET(XM+2+X1*2,YM+Y1*2+1)
9006 FORA=0TO60:NEXT
9010 IFA$=""THEN9000
9015 PRESET(XM+2+X1*2,YM+Y1*2+1)
9020 RETURN
9980 PRINTTIME$
9990 PRINT"Error!":END
10000 Z0=X*10+Y
10030 IFZ0<0ORZ0>99THEN11000
10040 POKEAA+Z0,Z
10080 RETURN
10100 Z0=X*10+Y
10130 IFZ0<0ORZ0>99THEN11000
10140 Z=PEEK(AA+Z0)
10180 RETURN
10200 IFZ<0ORZ>3THENPRINT"Boom!!!!":ERROR6
10205 Z1=PW(Z)
10210 GOSUB10100
10220 Z=ZANDZ1
10230 RETURN
10300 Z1=PW(Z)
10310 GOSUB10100
10320 Z=ZORZ1
10330 GOSUB10000
10340 RETURN
11000 PRINT"error!!!":BEEP:END
60000 DATA0,3,8.667,11,12.33,13.33,14
