#!/bin/bash -e
# co2do.sh
# by hackerb9, February 2026
#
# Given a .CO machine language file for a TRS-80 Model 100 (or
# similar), creates a .DO file containing a two-stage BASIC loader
# which will install the .CO to the correct address and start it.

# This program uses a small assembly routine to decode and write the
# bytes to memory, which is a hundred times faster than doing it in
# BASIC. See decode.asm and the dodo() function.
#
# USAGE: co2do.sh FOO.CO FOO.DO
#        Transfer FOO.DO to M100.
#        On M100: run "FOO"
#
# Features:
#
# * BASIC loader writes .CO to memory very quickly (less than a second).
#
# * Inspired by Stephen Adolph's efficient encoding scheme which
#   increases storage size by at most 2x + k (where k is approx. 500),
#   and on average closer to 1.3x + k.
#
# * Works on almost any of the Kyotronic Sisters: 
#     Kyocera Kyotronic 85, TRS-80 Model 100/102, Tandy 200, and Olivetti M10.
#
# * BASIC Automatically CLEARs the correct space and CALLs the program.
#
# * Uses .CO header to detect where to POKE, length mismatch, and CALL addr.
#
# * As a special bonus, if you use the -t option, it will display a
#   Unicode version of the program instead of writing to a .DO file.
#   (Requires the tandy-200.charmap file from hackerb9/tandy-locale.)

# Todo: 
#       * Prevent writing to bad parts of RAM.
#         (E.g., POKE Q where Q<HIMEM or Q>=MAXRAM).
#       * Fix ML part to be cross platform.
#       * NEC PC-8201A/8300 support coming soon!
#

function usage() {
    cat <<EOF
Usage: co2do.sh <INPUT.CO> [OUTPUT.DO]
EOF
}

function main() {
    declare -i TOP LEN EXE
    TOP=$1+$2*256
    LEN=$3+$4*256
    EXE=$5+$6*256
    shift 6
    if [[ ! $quiet ]]; then
	cat<<-EOF >&2
		TOP: $TOP
		END: $((TOP+LEN))
		EXE: $EXE
	EOF
    fi	
    if [[ $# -ne $LEN ]]; then
	echo "Warning filesize mismatch! $# bytes found after header, not $LEN." >&2
	if [[ $# -gt $LEN ]]; then
	    echo "Truncating output to $LEN bytes." >&2
	    set -- "${@:1:LEN}"
	fi
    fi
    if (( TOP<62960 && TOP>32767 )); then clear=", $TOP"; else clear=""; fi
    cat <<-EOF
	10 MAXFILES=0: CLEAR 256$clear: NM$="$(basename "$input")"
	20 DEFINT A-Z: TP=$((TOP-65536)): LN=$LEN: EX=$((EXE-65536))
	40 GOSUB 12000: GOSUB 13000
	50 IF PEEK(1)<>148 THEN CALL EX ELSE EXEC EX
	90 END
	EOF
    emitmldecode
    emitbasicdecode
    printf "14000 '$(basename "$input")"
    emitdata "$@"
    true			# XXX todo: call external warnmem util
    return			# Return result from warnmem
}

function emitdata() {
    local -i linenum=14000 
    local -i v
    for v; do
	if (( count++ % 120 == 0 )); then
	    printf '\n%d DATA"' $((linenum+=10))
	fi
	# Escape Quote (34), Bang (33), DEL (127), and ctrl chars (except Tab)
	if (( (v<35 && v!=9 && v!=32) || v==127 )); then
	    v=v+128
	    printf "!"
	fi
	printf -v x "%x" $v
	printf "\x$x"
    done
    # End of DATA marked by 'EOD'
    printf '\n%d DATA EOD\n' $((linenum+=10))
}

function emitmldecode() {
    # BASIC wrapper for the M/L routine to decode DATA strings fast.
    # Sets the BASIC variable DC to the address of the routine.
    # NB: the machine language is stored in a BASIC string and called
    # directly, so any further string manipulations in BASIC can foul
    # it up. (READ is okay.)
    cat <<-EOF
	12000 'Install tiny M/L program in DC$
	12001 'to decode and install main prg.
	12003 'Set no strings after this!
	12005 RESTORE 12000
	12010 DC$=SPACE\$(99): D=VARPTR(DC$): DC=PEEK(D+1)+256*PEEK(D+2)-65536: Q=DC
	12020 READ X
	12030 IF X=-1 THEN 12080
	12040 IF X=-7 THEN READ L: READ H: A=H*256+L+DC: H=INT(A/256): L=A-H*256: POKE Q, L: Q=Q+1: X=H+256
	12050 POKE Q, X
	12060 Q=Q+1
	12070 GOTO 12020 
	12080 POKE D, Q-DC: 'Set length of DC$
	12090 RETURN
	EOF
    dodo decode.asm.lst
}

function emitbasicdecode() {
    # Calls M/L routine to decode and install each DATA string.
    # DC is the start address of decode.asm, set by emitmlcode().
    # TP is the destination address ("TOP"), set by main().
    cat <<-"EOF"
	13000 REM ?"Loading "NM$" ("LN" bytes) at "TP
	13010 RESTORE 13000
	13020 CALL DC, 0, TP
	13030 READP$: IF P$="EOD" GOTO 13080
	13050 CALL DC+6, 0, VARPTR(P$)
	13060 GOTO 13030
	13080 'All done
	13090 ?:RETURN
	EOF
}

function dodo() {
    # dodo: DATA output decode.asm to .DO.
    # Given the filename of an assembly listing (from `asmx -l`), output
    # the bytes as decimal values separated by commas in a DATA statement. 
    # Addresses that will need to be relocated are prefixed with -7.
    # End of data is signaled by -1.
    echo -n "12500 DATA "
    cat "$@" | parselst
    echo -1
    return
}

function parselst() {
    # Parse an assembly listing on stdin and output data values.
    # Whenever an address is seen, prefix it with -7.
    # This routine is fragile, but it only needs to work with one
    # program: decode.asm (which see). Also see, dodo().
    sed -rn '/^[0-9A-Fa-f]{4} /p' | cut -c 6-19 | 
	while read op arg; do
	    case ${#op} in
		0) continue ;;
		2) echo "ibase=16; $op" | bc ;;
		4) # Data for DW looks like a 16-bit opcode.
		    echo "ibase=16; ${op:0:2}" | bc
		    echo "ibase=16; ${op:2:2}" | bc
		    ;;
		*)
		    echo "parselst error: What is op in '$op $arg'?" >&2
	    esac
	    case ${#arg} in
		0) continue ;;
		2) echo "ibase=16; $arg" | bc ;;
		4) # Escape address for relocation with -7
		    echo -7
		    echo "ibase=16; ${arg:0:2}" | bc
		    echo "ibase=16; ${arg:2:2}" | bc
		    ;;
		*)
		    echo "parselst error: What is arg in '$op $arg'?" >&2
	    esac
	done | tr -s '\n' ','
}


{    # CLI args
    tandycharset=cat
    quiet=""
    while getopts 'qt' name; do
	case $name in
	    q) quiet=: ;;
	    t) tandycharset="iconv -f $(dirname $0)/tandy-200.charmap"  ;;
	    *) exit 1 ;;
	esac
    done
    shift $(($OPTIND - 1))

    if [ -z "$1" ]; then usage; exit 1; fi
    if [[ "$1" == "-" ]]; then shift; set -- /dev/stdin "$@"; fi
    if [ ! -r "$1" ]; then
	echo "'$1' is not readable"
	exit 1
    else
	input="$1"
	shift
    fi

    output=/dev/stdout
    if [ "$1" ]; then
	output="$1"
	shift
    elif [[ $tandycharset == "cat" ]]; then
	if [[ $input == *.CO ]]; then
	    output=${input%.CO}.DO
	elif [[ $input == *.co ]]; then
	    output=${input%.co}.do
	fi
    fi
}

outputfilter() {
    # Add carriage returns since NEC PC-8201 uses Mac (or DOS?) line endings.
    # Append ^Z at end of file to signal M100 that file is finished.
    sed 's/$/\r/g'
    printf '\x1A'
}


main $(od -t u1 -v -An "$input") | $tandycharset | outputfilter > "$output"
err=${PIPESTATUS[0]}

if [[ $tandycharset == "cat" && -z $quiet ]]; then
    outnodo=${output##*/}
    outnodo=${outnodo%.[Dd][Oo]}
    cat <<-EOF
	Now transfer $output to your Model-T
	and in BASIC type
	    run "${outnodo:0:6}"
	EOF
fi

exit $err
